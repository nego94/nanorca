# ══════════════════════════════════════════════════════════════════════════════
# NANORCA — Environment Variables Template
# Copy this file to .env and fill in your real values.
# NEVER commit .env to git. It is in .gitignore.
# ══════════════════════════════════════════════════════════════════════════════

# ── ANTHROPIC (AI Brain) ──────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-xxxx
# Fast model for routine decisions (cheap — ~$0.25/M tokens)
CLAUDE_MODEL_FAST=claude-haiku-4-5-20251001
# Deep model for weekly learning analysis (more expensive)
CLAUDE_MODEL_DEEP=claude-sonnet-4-6
CLAUDE_MAX_TOKENS=1000
# Low temperature = consistent, deterministic trading decisions
CLAUDE_TEMPERATURE=0.1

# ── BINANCE ───────────────────────────────────────────────────────────────────
BINANCE_API_KEY=xxxx
BINANCE_API_SECRET=xxxx
# true = use Binance testnet (safe for paper trading)
BINANCE_TESTNET=true

# ── POLYMARKET ────────────────────────────────────────────────────────────────
# New Relayer API (deprecated secret+passphrase no longer needed)
# Private key: export from Magic wallet → polymarket.com profile
POLYMARKET_PRIVATE_KEY=0xxxxx
# From polymarket.com/settings?tab=api-keys → Create API Key
POLYMARKET_RELAYER_API_KEY=xxxx
# "Signer Address" shown next to your API key — this is the key address, not a secret
POLYMARKET_RELAYER_KEY_ADDRESS=0xxxxx
POLYMARKET_HOST=https://relayer-v2.polymarket.com

# ── HYPERLIQUID ───────────────────────────────────────────────────────────────
HYPERLIQUID_PRIVATE_KEY=0xxxxx
HYPERLIQUID_ACCOUNT_ADDRESS=0xxxxx
# true = use Hyperliquid testnet
HYPERLIQUID_TESTNET=true

# ── DATABASE ──────────────────────────────────────────────────────────────────
# Host must match Docker service name (postgres) — never 'localhost' inside Docker
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=nanorca
POSTGRES_USER=nanorca_user
# Use a strong password — min 20 chars, mixed case + symbols
POSTGRES_PASSWORD=choose_strong_password_here

# ── TELEGRAM ──────────────────────────────────────────────────────────────────
# Get bot token from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=xxxx:xxxx
# Your own Telegram user ID — get it from @userinfobot (DM the bot).
# This is the OWNER: can run ALL commands including pause/resume/setfloor.
TELEGRAM_CHAT_ID=xxxx
# Extra users allowed to use read-only commands (status, capital, markets, etc.)
# Comma-separated user IDs. Get each person's ID from @userinfobot.
# Owner is always included automatically — no need to repeat TELEGRAM_CHAT_ID here.
# Example: TELEGRAM_ALLOWED_USER_IDS=123456789,987654321
TELEGRAM_ALLOWED_USER_IDS=

# ── CALLMEBOT (WHATSAPP FALLBACK) ─────────────────────────────────────────────
# Used ONLY for 🚨 critical alerts (capital floor hit)
# Get API key from callmebot.com
CALLMEBOT_PHONE=+62xxxxxxxxxx
CALLMEBOT_API_KEY=xxxx

# ── GRAFANA ───────────────────────────────────────────────────────────────────
# Dashboard admin password — change this!
GRAFANA_ADMIN_PASSWORD=choose_dashboard_password_here

# ── CAPITAL & RISK ────────────────────────────────────────────────────────────
# Starting capital in USD — minimum $10 for testing (paper mode works at any size)
STARTING_CAPITAL_USD=10.00
# Alert + pause if capital drops this % from starting capital
CAPITAL_FLOOR_PCT=25
# Max % of capital per single trade — set to 20% for $10 testing ($2/trade)
# Recommended: drop to 5% once capital > $200
MAX_POSITION_PCT=20
# Pause for the day if daily loss hits this %
MAX_DAILY_LOSS_PCT=8
# Pause after N consecutive losing trades (2-hour cooldown)
CIRCUIT_BREAKER_CONSECUTIVE=3
# Minimum confidence score (0–100) to execute a trade
CONFIDENCE_THRESHOLD=65

# ── OPERATION MODE ────────────────────────────────────────────────────────────
# ALWAYS start true. Only set false after 14+ days of profitable paper trading.
PAPER_TRADING=true
# How often the bot scans all markets (seconds)
SCAN_INTERVAL_SECONDS=60
# Owner timezone — used for midnight daily report
BOT_TIMEZONE=Asia/Makassar

# ── MARKETS ───────────────────────────────────────────────────────────────────
# Comma-separated. Bot scans these first, others are secondary.
PRIORITY_MARKETS=BTC,ETH,SOL

# ── NEWS SCRAPING ─────────────────────────────────────────────────────────────
# CoinMarketCap API key — get from coinmarketcap.com/api
CMC_API_KEY=xxxx
# Twitter/X Bearer Token — get from developer.twitter.com
TWITTER_BEARER_TOKEN=xxxx

# ── GO EXECUTOR SERVICE ───────────────────────────────────────────────────────
EXECUTOR_GRPC_HOST=executor
EXECUTOR_GRPC_PORT=50051

# ── LOGGING ───────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
# Logs are written to /app/logs/ inside the bot container (mounted as ./logs/)

# ── TRADING PLAN ──────────────────────────────────────────────────────────────
# Controls how the bot sizes positions and manages risk.
#
# nanorca_decide  — Claude picks size from confidence score (default)
#                   Leverage: none (1x). Claude handles all sizing logic.
#
# conservative    — Survive long-term, minimize blowups
#                   Formula: R = 10 / C^0.10  |  Max exposure: 30% capital
#                   $10–$100: 7.5% risk, 5x lev, 1.5% daily goal
#                   $100–$1k: 4.0% risk, 3x lev, 1.0% daily goal
#
# aggressive      — Fast growth, higher volatility tolerated
#                   Formula: R = 40 / C^0.25  |  Max exposure: 60% capital
#                   $10–$100: 17.5% risk, 10x lev (capped), 3.5% daily goal
#                   $100–$1k:  11% risk, 7x lev, 2.0% daily goal
#                   WARNING: high chance of large drawdowns at small capital
#
# hybrid          — Aggressive when small, conservative when large (RECOMMENDED)
#                   < $1,000:  uses aggressive tier
#                   $1k–$10k:  blends both
#                   > $10,000: uses conservative tier
#
# NOTE: Polymarket always uses 1x leverage regardless of mode (no margin).
# NOTE: Binance hard-capped at 3x. Hyperliquid hard-capped at 10x.
TRADING_MODE=hybrid
