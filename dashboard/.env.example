# Dashboard environment variables
# Copy to .env.local for local dev, or set in docker-compose.yml for production

# PostgreSQL connection (same DB the bot uses)
DATABASE_URL=postgresql://nanorca_user:YOURPASSWORD@localhost:5432/nanorca

# In Docker, use internal hostname:
# DATABASE_URL=postgresql://nanorca_user:YOURPASSWORD@postgres:5432/nanorca

# Optional: base URL for internal API calls (leave empty for same-origin)
NEXT_PUBLIC_API_URL=
