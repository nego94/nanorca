{
  "title": "NANORCA Trading Dashboard",
  "uid": "nanorca-main",
  "schemaVersion": 38,
  "version": 4,
  "refresh": "30s",
  "templating": {
    "list": [
      {
        "name": "mode",
        "type": "custom",
        "label": "Mode",
        "description": "Filter trade history by paper or live",
        "query": "all,paper,live",
        "options": [
          {"selected": true,  "text": "All trades", "value": "all"},
          {"selected": false, "text": "Paper",       "value": "paper"},
          {"selected": false, "text": "Live",        "value": "live"}
        ],
        "current": {"selected": true, "text": "All trades", "value": "all"},
        "hide": 0,
        "multi": false,
        "includeAll": false
      }
    ]
  },
  "panels": [

    {"id":1,"title":"Bot State","type":"stat","gridPos":{"x":0,"y":0,"w":4,"h":3},
     "targets":[{"expr":"nanorca_bot_state","refId":"A"}],
     "fieldConfig":{"defaults":{"mappings":[{"type":"value","options":{
       "0":{"text":"🟢 Running","color":"green"},"1":{"text":"⏸️ Paused","color":"yellow"},
       "2":{"text":"🔴 Floor Hit","color":"red"},"3":{"text":"🟡 Daily Loss","color":"orange"},
       "4":{"text":"🟡 Circuit","color":"orange"}}}]}}},

    {"id":2,"title":"Mode","type":"stat","gridPos":{"x":4,"y":0,"w":4,"h":3},
     "targets":[{"expr":"nanorca_paper_mode","refId":"A"}],
     "fieldConfig":{"defaults":{"mappings":[{"type":"value","options":{
       "1":{"text":"📄 PAPER","color":"blue"},"0":{"text":"🔴 LIVE","color":"red"}}}]}}},

    {"id":3,"title":"📄 Paper Capital","type":"stat","gridPos":{"x":8,"y":0,"w":4,"h":3},
     "description":"Simulated paper trading capital. Grows/shrinks with paper trade results. NOT real money — for data collection and strategy validation only.",
     "targets":[{"expr":"nanorca_capital_current_usd","refId":"A"}],
     "fieldConfig":{"defaults":{"unit":"currencyUSD","color":{"mode":"thresholds"},
       "thresholds":{"steps":[{"value":null,"color":"red"},{"value":5,"color":"yellow"},{"value":10,"color":"blue"}]},
       "noValue":"$0.00"}}},

    {"id":4,"title":"💳 Real USDT (Binance)","type":"stat","gridPos":{"x":12,"y":0,"w":4,"h":3},
     "description":"Actual Binance USDT-M futures wallet balance. This is real money, separate from the paper simulation.",
     "targets":[{"expr":"nanorca_capital_tradeable_usd{exchange=\"binance\"}","refId":"A"}],
     "fieldConfig":{"defaults":{"unit":"currencyUSD","color":{"mode":"thresholds"},
       "thresholds":{"steps":[{"value":null,"color":"red"},{"value":1,"color":"yellow"},{"value":10,"color":"green"}]},
       "noValue":"$0.00"}}},

    {"id":5,"title":"24h P&L (paper)","type":"stat","gridPos":{"x":16,"y":0,"w":4,"h":3},
     "description":"Paper trading profit/loss in the last 24 hours. From closed paper trades in DB.",
     "targets":[{"expr":"nanorca_daily_pnl_usd","refId":"A"}],
     "fieldConfig":{"defaults":{"unit":"currencyUSD","color":{"mode":"thresholds"},
       "thresholds":{"steps":[{"value":null,"color":"red"},{"value":0,"color":"yellow"},{"value":0.01,"color":"green"}]}}}},

    {"id":6,"title":"Open Positions","type":"stat","gridPos":{"x":20,"y":0,"w":4,"h":3},
     "targets":[{"expr":"nanorca_open_positions_count","refId":"A"}],
     "fieldConfig":{"defaults":{"unit":"short"}}},

    {"id":100,"title":"── LIVE SIGNALS (what Claude sees right now) ──","type":"text",
     "gridPos":{"x":0,"y":3,"w":24,"h":1},
     "options":{"mode":"markdown","content":"## 🔍 Live Signals — What the Bot Is Watching"}},

    {"id":11,"title":"📈 Binance Momentum","type":"gauge","gridPos":{"x":0,"y":4,"w":6,"h":5},
     "description":"5-min price change across BTC/ETH/SOL. Fires at ±1.5%. -3%→0, flat→0.5, +3%→1.0",
     "targets":[{"expr":"nanorca_signal_normalized{signal=\"binance_momentum\"}","refId":"A"}],
     "fieldConfig":{"defaults":{"min":0,"max":1,"thresholds":{"steps":[
       {"value":null,"color":"red"},{"value":0.35,"color":"orange"},{"value":0.45,"color":"yellow"},
       {"value":0.55,"color":"yellow"},{"value":0.65,"color":"orange"},{"value":0.75,"color":"green"}]},
       "mappings":[]},
      "overrides":[]}},

    {"id":12,"title":"💰 HL Funding Rate","type":"gauge","gridPos":{"x":6,"y":4,"w":6,"h":5},
     "description":"Hyperliquid avg funding rate. 0=pay longs (go long), 0.5=neutral, 1=pay shorts (go short)",
     "targets":[{"expr":"nanorca_signal_normalized{signal=\"funding_rate_hyperliquid\"}","refId":"A"}],
     "fieldConfig":{"defaults":{"min":0,"max":1,"thresholds":{"steps":[
       {"value":null,"color":"blue"},{"value":0.3,"color":"green"},{"value":0.45,"color":"yellow"},
       {"value":0.55,"color":"yellow"},{"value":0.7,"color":"orange"},{"value":0.85,"color":"red"}]},
       "mappings":[]}}},

    {"id":13,"title":"🎯 Polymarket Gap","type":"gauge","gridPos":{"x":12,"y":4,"w":6,"h":5},
     "description":"YES+NO price deviation from 1.0. Gap >2% = arbitrage opportunity. 0=no gap, 1=5% gap",
     "targets":[{"expr":"nanorca_signal_normalized{signal=\"price_gap_polymarket\"}","refId":"A"}],
     "fieldConfig":{"defaults":{"min":0,"max":1,"thresholds":{"steps":[
       {"value":null,"color":"grey"},{"value":0.01,"color":"yellow"},{"value":0.4,"color":"green"}]},
       "mappings":[]}}},

    {"id":14,"title":"📊 Volume Spike","type":"gauge","gridPos":{"x":18,"y":4,"w":6,"h":5},
     "description":"Cross-exchange volume vs 7-cycle EMA baseline. 0=normal, 1=2× baseline (spike)",
     "targets":[{"expr":"nanorca_signal_normalized{signal=\"volume_spike\"}","refId":"A"}],
     "fieldConfig":{"defaults":{"min":0,"max":1,"thresholds":{"steps":[
       {"value":null,"color":"grey"},{"value":0.15,"color":"yellow"},{"value":0.3,"color":"green"}]},
       "mappings":[]}}},

    {"id":200,"title":"── CLAUDE DECISIONS ──","type":"text",
     "gridPos":{"x":0,"y":9,"w":24,"h":1},
     "options":{"mode":"markdown","content":"## 🧠 Claude AI Decisions"}},

    {"id":21,"title":"Last Action","type":"stat","gridPos":{"x":0,"y":10,"w":6,"h":4},
     "targets":[{"expr":"nanorca_claude_last_action","refId":"A"}],
     "fieldConfig":{"defaults":{"mappings":[{"type":"value","options":{
       "0":{"text":"⏭️ Skip","color":"grey"},
       "1":{"text":"🟢 Buy","color":"green"},
       "2":{"text":"🔴 Sell","color":"red"}}}]}}},

    {"id":22,"title":"Last Confidence","type":"gauge","gridPos":{"x":6,"y":10,"w":6,"h":4},
     "targets":[{"expr":"nanorca_claude_last_confidence","refId":"A"}],
     "fieldConfig":{"defaults":{"min":0,"max":100,"unit":"none","thresholds":{"steps":[
       {"value":null,"color":"grey"},{"value":50,"color":"yellow"},{"value":65,"color":"green"},
       {"value":80,"color":"blue"}]}}}},

    {"id":23,"title":"Market Snapshots / Scan","type":"stat","gridPos":{"x":12,"y":10,"w":6,"h":4},
     "targets":[{"expr":"nanorca_market_snapshots_last","refId":"A"}],
     "fieldConfig":{"defaults":{"unit":"short","color":{"mode":"thresholds"},
       "thresholds":{"steps":[{"value":null,"color":"red"},{"value":10,"color":"yellow"},{"value":100,"color":"green"}]}}}},

    {"id":24,"title":"Total Claude Cycles","type":"stat","gridPos":{"x":18,"y":10,"w":6,"h":4},
     "targets":[{"expr":"nanorca_claude_cycles_total","refId":"A"}],
     "fieldConfig":{"defaults":{"unit":"short"}}},

    {"id":300,"title":"── SIGNALS OVER TIME ──","type":"text",
     "gridPos":{"x":0,"y":14,"w":24,"h":1},
     "options":{"mode":"markdown","content":"## 📉 Signal History"}},

    {"id":31,"title":"All Signals — 0.5=Neutral, >0.65=Action Zone","type":"timeseries",
     "gridPos":{"x":0,"y":15,"w":24,"h":8},
     "targets":[
       {"expr":"nanorca_signal_normalized{signal=\"binance_momentum\"}","legendFormat":"Momentum","refId":"A"},
       {"expr":"nanorca_signal_normalized{signal=\"funding_rate_hyperliquid\"}","legendFormat":"HL Funding","refId":"B"},
       {"expr":"nanorca_signal_normalized{signal=\"price_gap_polymarket\"}","legendFormat":"Poly Gap","refId":"C"},
       {"expr":"nanorca_signal_normalized{signal=\"volume_spike\"}","legendFormat":"Volume Spike","refId":"D"},
       {"expr":"nanorca_claude_last_confidence / 100","legendFormat":"Claude Confidence (/100)","refId":"E"}
     ],
     "fieldConfig":{"defaults":{"min":0,"max":1,"unit":"percentunit","custom":{"lineWidth":2}}}},

    {"id":400,"title":"── PERFORMANCE ──","type":"text",
     "gridPos":{"x":0,"y":23,"w":24,"h":1},
     "options":{"mode":"markdown","content":"## 💹 Performance"}},

    {"id":41,"title":"📄 Paper Capital vs 💳 Real Balance","type":"timeseries",
     "description":"Paper capital (blue) = simulated trading account — grows with paper wins. Real USDT (green) = actual Binance wallet — not affected by paper trades.",
     "gridPos":{"x":0,"y":24,"w":16,"h":7},
     "targets":[
       {"expr":"nanorca_capital_current_usd","legendFormat":"📄 Paper Capital (simulated)","refId":"A"},
       {"expr":"nanorca_capital_tradeable_usd{exchange=\"binance\"}","legendFormat":"💳 Real USDT (Binance)","refId":"B"},
       {"expr":"nanorca_capital_locked_usd{exchange=\"binance\"}","legendFormat":"🔒 Locked Coins (Binance)","refId":"C"}
     ],
     "fieldConfig":{"defaults":{"unit":"currencyUSD","custom":{"lineWidth":2}},
       "overrides":[
         {"matcher":{"id":"byName","options":"📄 Paper Capital (simulated)"},"properties":[{"id":"color","value":{"mode":"fixed","fixedColor":"blue"}}]},
         {"matcher":{"id":"byName","options":"💳 Real USDT (Binance)"},"properties":[{"id":"color","value":{"mode":"fixed","fixedColor":"green"}}]},
         {"matcher":{"id":"byName","options":"🔒 Locked Coins (Binance)"},"properties":[{"id":"color","value":{"mode":"fixed","fixedColor":"orange"}}]}
       ]}},

    {"id":42,"title":"Win Rates","type":"gauge","gridPos":{"x":16,"y":24,"w":8,"h":7},
     "targets":[
       {"expr":"nanorca_win_rate_24h * 100","legendFormat":"24h","refId":"A"},
       {"expr":"nanorca_win_rate_7d * 100","legendFormat":"7d","refId":"B"}
     ],
     "fieldConfig":{"defaults":{"unit":"percent","min":0,"max":100,"thresholds":{"steps":[
       {"value":null,"color":"red"},{"value":50,"color":"yellow"},{"value":65,"color":"green"}]}}}},

    {"id":500,"title":"── EXCHANGES ──","type":"text",
     "gridPos":{"x":0,"y":31,"w":24,"h":1},
     "options":{"mode":"markdown","content":"## 🔗 Exchange Connectivity & Balances"}},

    {"id":51,"title":"🟡 Binance","type":"stat","gridPos":{"x":0,"y":32,"w":8,"h":4},
     "targets":[{"expr":"nanorca_exchange_balance_usd{exchange=\"binance\"}","refId":"A"}],
     "fieldConfig":{"defaults":{"unit":"currencyUSD","noValue":"$0.00",
       "color":{"mode":"thresholds"},"thresholds":{"steps":[{"value":null,"color":"red"},{"value":0.01,"color":"green"}]}}}},

    {"id":52,"title":"🔵 Hyperliquid","type":"stat","gridPos":{"x":8,"y":32,"w":8,"h":4},
     "targets":[{"expr":"nanorca_exchange_balance_usd{exchange=\"hyperliquid\"}","refId":"A"}],
     "fieldConfig":{"defaults":{"unit":"currencyUSD","noValue":"$0.00",
       "color":{"mode":"thresholds"},"thresholds":{"steps":[{"value":null,"color":"red"},{"value":0.01,"color":"green"}]}}}},

    {"id":53,"title":"🟣 Polymarket","type":"stat","gridPos":{"x":16,"y":32,"w":8,"h":4},
     "targets":[{"expr":"nanorca_exchange_balance_usd{exchange=\"polymarket\"}","refId":"A"}],
     "fieldConfig":{"defaults":{"unit":"currencyUSD","noValue":"Not configured",
       "color":{"mode":"thresholds"},"thresholds":{"steps":[{"value":null,"color":"grey"},{"value":0.01,"color":"green"}]}}}},

    {"id":54,"title":"Errors","type":"timeseries","gridPos":{"x":0,"y":36,"w":24,"h":5},
     "targets":[
       {"expr":"increase(nanorca_scan_errors_total[5m])","legendFormat":"Scan errors","refId":"A"},
       {"expr":"increase(nanorca_claude_errors_total[5m])","legendFormat":"Claude errors","refId":"B"},
       {"expr":"increase(nanorca_skips_total[5m])","legendFormat":"Skips (low confidence)","refId":"C"},
       {"expr":"increase(nanorca_trades_total[5m])","legendFormat":"Trades executed","refId":"D"}
     ]},

    {"id":600,"title":"── TRADE HISTORY (from Database) ──","type":"text",
     "gridPos":{"x":0,"y":41,"w":24,"h":1},
     "options":{"mode":"markdown","content":"## 📋 Trade History — Direct from PostgreSQL"}},

    {"id":61,"title":"Recent Trades","type":"table",
     "gridPos":{"x":0,"y":42,"w":24,"h":10},
     "datasource":{"type":"postgres","uid":"nanorca-postgres"},
     "targets":[{"refId":"A","rawSql":"SELECT\n  to_char(COALESCE(opened_at, created_at) AT TIME ZONE 'Asia/Makassar', 'YYYY-MM-DD HH24:MI') AS \"Opened (WIB)\",\n  to_char(closed_at AT TIME ZONE 'Asia/Makassar', 'HH24:MI') AS \"Closed\",\n  CASE WHEN paper THEN '📄 Paper' ELSE '🔴 Live' END AS \"Mode\",\n  market AS \"Market\",\n  UPPER(direction) AS \"Dir\",\n  ROUND(entry_price, 4) AS \"Entry\",\n  ROUND(exit_price, 4) AS \"Exit\",\n  ROUND(size_usd, 2) AS \"Size $\",\n  ROUND(pnl_usd, 4) AS \"P&L $\",\n  hold_minutes AS \"Hold (min)\",\n  confidence_score AS \"Conf\",\n  CASE WHEN win THEN '✅ Win' WHEN win IS FALSE THEN '❌ Loss' ELSE '🔄 Open' END AS \"Result\"\nFROM trades\nWHERE ('${mode}' = 'all' OR ('${mode}' = 'paper' AND paper = true) OR ('${mode}' = 'live' AND paper = false))\nORDER BY COALESCE(opened_at, created_at) DESC\nLIMIT 50","format":"table"}],
     "fieldConfig":{"overrides":[
       {"matcher":{"id":"byName","options":"P&L $"},"properties":[
         {"id":"custom.displayMode","value":"color-text"},
         {"id":"thresholds","value":{"steps":[{"value":null,"color":"red"},{"value":0,"color":"green"}]}}
       ]},
       {"matcher":{"id":"byName","options":"Confidence"},"properties":[
         {"id":"custom.displayMode","value":"gradient-gauge"},
         {"id":"min","value":0},{"id":"max","value":100}
       ]}
     ]}},

    {"id":62,"title":"Cumulative P&L Over Time","type":"timeseries",
     "gridPos":{"x":0,"y":52,"w":16,"h":7},
     "datasource":{"type":"postgres","uid":"nanorca-postgres"},
     "targets":[
       {"refId":"A","rawSql":"SELECT\n  closed_at AS time,\n  SUM(COALESCE(pnl_usd,0)) OVER (ORDER BY closed_at ROWS UNBOUNDED PRECEDING) AS \"📄 Paper P&L\"\nFROM trades\nWHERE status = 'closed' AND closed_at IS NOT NULL AND paper = true\nORDER BY closed_at","format":"time_series"},
       {"refId":"B","rawSql":"SELECT\n  closed_at AS time,\n  SUM(COALESCE(pnl_usd,0)) OVER (ORDER BY closed_at ROWS UNBOUNDED PRECEDING) AS \"🔴 Live P&L\"\nFROM trades\nWHERE status = 'closed' AND closed_at IS NOT NULL AND paper = false\nORDER BY closed_at","format":"time_series"}
     ],
     "fieldConfig":{"defaults":{"unit":"currencyUSD","custom":{"lineWidth":2,"fillOpacity":10}}}},

    {"id":63,"title":"Win / Loss Count","type":"piechart",
     "gridPos":{"x":16,"y":52,"w":8,"h":7},
     "datasource":{"type":"postgres","uid":"nanorca-postgres"},
     "targets":[{"refId":"A","rawSql":"SELECT\n  CASE WHEN win THEN 'Win ✅' ELSE 'Loss ❌' END AS label,\n  COUNT(*) AS count\nFROM trades\nWHERE status = 'closed' AND win IS NOT NULL AND ('${mode}' = 'all' OR ('${mode}' = 'paper' AND paper = true) OR ('${mode}' = 'live' AND paper = false))\nGROUP BY win","format":"table"}],
     "fieldConfig":{"defaults":{"color":{"mode":"palette-classic"}}}},

    {"id":64,"title":"P&L by Market (all time)","type":"barchart",
     "gridPos":{"x":0,"y":59,"w":12,"h":7},
     "datasource":{"type":"postgres","uid":"nanorca-postgres"},
     "targets":[{"refId":"A","rawSql":"SELECT\n  market AS \"Market\",\n  ROUND(SUM(COALESCE(pnl_usd,0)),4) AS \"Total P&L\"\nFROM trades\nWHERE status = 'closed' AND ('${mode}' = 'all' OR ('${mode}' = 'paper' AND paper = true) OR ('${mode}' = 'live' AND paper = false))\nGROUP BY market\nORDER BY SUM(COALESCE(pnl_usd,0)) DESC\nLIMIT 15","format":"table"}],
     "fieldConfig":{"defaults":{"unit":"currencyUSD"}}},

    {"id":65,"title":"📄 Paper Stats","type":"stat",
     "gridPos":{"x":0,"y":59,"w":12,"h":7},
     "datasource":{"type":"postgres","uid":"nanorca-postgres"},
     "targets":[
       {"refId":"A","rawSql":"SELECT COUNT(*) AS \"Closed Trades\" FROM trades WHERE status='closed' AND paper=true","format":"table"},
       {"refId":"B","rawSql":"SELECT ROUND(AVG(CASE WHEN win THEN 1.0 ELSE 0.0 END)*100,1) AS \"Win Rate %\" FROM trades WHERE status='closed' AND paper=true AND win IS NOT NULL","format":"table"},
       {"refId":"C","rawSql":"SELECT ROUND(SUM(COALESCE(pnl_usd,0)),4) AS \"Total P&L $\" FROM trades WHERE status='closed' AND paper=true","format":"table"},
       {"refId":"D","rawSql":"SELECT ROUND(AVG(hold_minutes),1) AS \"Avg Hold (min)\" FROM trades WHERE status='closed' AND paper=true AND hold_minutes IS NOT NULL","format":"table"}
     ],
     "options":{"reduceOptions":{"calcs":["lastNotNull"]},"colorMode":"background"},
     "fieldConfig":{"defaults":{"color":{"mode":"thresholds"},"thresholds":{"steps":[{"value":null,"color":"blue"}]}}}},

    {"id":66,"title":"🔴 Live Stats","type":"stat",
     "gridPos":{"x":12,"y":59,"w":12,"h":7},
     "datasource":{"type":"postgres","uid":"nanorca-postgres"},
     "targets":[
       {"refId":"A","rawSql":"SELECT COUNT(*) AS \"Closed Trades\" FROM trades WHERE status='closed' AND paper=false","format":"table"},
       {"refId":"B","rawSql":"SELECT ROUND(AVG(CASE WHEN win THEN 1.0 ELSE 0.0 END)*100,1) AS \"Win Rate %\" FROM trades WHERE status='closed' AND paper=false AND win IS NOT NULL","format":"table"},
       {"refId":"C","rawSql":"SELECT ROUND(SUM(COALESCE(pnl_usd,0)),4) AS \"Total P&L $\" FROM trades WHERE status='closed' AND paper=false","format":"table"},
       {"refId":"D","rawSql":"SELECT ROUND(AVG(hold_minutes),1) AS \"Avg Hold (min)\" FROM trades WHERE status='closed' AND paper=false AND hold_minutes IS NOT NULL","format":"table"}
     ],
     "options":{"reduceOptions":{"calcs":["lastNotNull"]},"colorMode":"background"},
     "fieldConfig":{"defaults":{"color":{"mode":"thresholds"},"thresholds":{"steps":[{"value":null,"color":"red"}]}}}},

    {"id":700,"title":"── CAPITAL BUCKETS ──","type":"text",
     "gridPos":{"x":0,"y":66,"w":24,"h":1},
     "options":{"mode":"markdown","content":"## 💼 Capital Buckets — Tradeable vs Locked vs In-flight\n\n**Tradeable USDT** = stablecoin margin for futures. **Locked** = other coins, cannot use directly. **In-flight** = capital in open positions."}},

    {"id":71,"title":"Capital Breakdown Over Time","type":"timeseries",
     "gridPos":{"x":0,"y":67,"w":16,"h":7},
     "targets":[
       {"expr":"nanorca_capital_tradeable_usd{exchange=\"binance\"}","legendFormat":"Tradeable USDT","refId":"A"},
       {"expr":"nanorca_capital_locked_usd{exchange=\"binance\"}","legendFormat":"Locked (other coins)","refId":"B"},
       {"expr":"nanorca_capital_current_usd","legendFormat":"Bot Tracked Capital","refId":"C"}
     ],
     "fieldConfig":{"defaults":{"unit":"currencyUSD","custom":{"lineWidth":2}}}},

    {"id":72,"title":"Current Buckets","type":"stat",
     "gridPos":{"x":16,"y":67,"w":8,"h":7},
     "description":"Three-bucket view: tradeable USDT the bot can use, locked coins it cannot, and the total portfolio value.",
     "targets":[
       {"expr":"nanorca_capital_tradeable_usd{exchange=\"binance\"}","legendFormat":"Tradeable USDT","refId":"A"},
       {"expr":"nanorca_capital_locked_usd{exchange=\"binance\"}","legendFormat":"Locked Coins","refId":"B"},
       {"expr":"nanorca_capital_tradeable_usd{exchange=\"binance\"} + nanorca_capital_locked_usd{exchange=\"binance\"}","legendFormat":"Portfolio Total","refId":"C"}
     ],
     "options":{"reduceOptions":{"calcs":["lastNotNull"]},"orientation":"vertical","colorMode":"background"},
     "fieldConfig":{"defaults":{"unit":"currencyUSD"}}}

  ]
}
