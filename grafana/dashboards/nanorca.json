{
  "__inputs": [{"name": "DS_PROMETHEUS", "label": "Prometheus", "type": "datasource", "pluginId": "prometheus"}],
  "__requires": [{"type": "datasource", "id": "prometheus", "name": "Prometheus", "version": "1.0.0"}],
  "title": "NANORCA Trading Dashboard",
  "uid": "nanorca-main",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "15s",
  "panels": [
    {
      "id": 1, "title": "Capital (USD)", "type": "stat",
      "gridPos": {"x": 0, "y": 0, "w": 6, "h": 4},
      "targets": [{"expr": "nanorca_capital_current_usd", "refId": "A"}],
      "fieldConfig": {"defaults": {"unit": "currencyUSD", "color": {"mode": "thresholds"},
        "thresholds": {"steps": [{"value": null, "color": "red"}, {"value": 80, "color": "yellow"}, {"value": 100, "color": "green"}]}}}
    },
    {
      "id": 2, "title": "% Change from Start", "type": "stat",
      "gridPos": {"x": 6, "y": 0, "w": 6, "h": 4},
      "targets": [{"expr": "nanorca_capital_pct_change", "refId": "A"}],
      "fieldConfig": {"defaults": {"unit": "percent"}}
    },
    {
      "id": 3, "title": "Daily P&L", "type": "stat",
      "gridPos": {"x": 12, "y": 0, "w": 6, "h": 4},
      "targets": [{"expr": "nanorca_daily_pnl_usd", "refId": "A"}],
      "fieldConfig": {"defaults": {"unit": "currencyUSD"}}
    },
    {
      "id": 4, "title": "Bot State", "type": "stat",
      "gridPos": {"x": 18, "y": 0, "w": 6, "h": 4},
      "targets": [{"expr": "nanorca_bot_state", "refId": "A"}],
      "fieldConfig": {"defaults": {"mappings": [
        {"type": "value", "options": {"0": {"text": "🟢 Running"}, "1": {"text": "⏸️ Manual Pause"}, "2": {"text": "🔴 Floor Hit"}, "3": {"text": "🟡 Daily Loss"}, "4": {"text": "🟡 Circuit Break"}}}
      ]}}
    },
    {
      "id": 5, "title": "Capital Over Time", "type": "timeseries",
      "gridPos": {"x": 0, "y": 4, "w": 24, "h": 8},
      "targets": [{"expr": "nanorca_capital_current_usd", "legendFormat": "Capital USD", "refId": "A"}],
      "fieldConfig": {"defaults": {"unit": "currencyUSD", "custom": {"lineWidth": 2}}}
    },
    {
      "id": 6, "title": "Win Rate 24h", "type": "gauge",
      "gridPos": {"x": 0, "y": 12, "w": 6, "h": 6},
      "targets": [{"expr": "nanorca_win_rate_24h * 100", "refId": "A"}],
      "fieldConfig": {"defaults": {"unit": "percent", "min": 0, "max": 100,
        "thresholds": {"steps": [{"value": null, "color": "red"}, {"value": 50, "color": "yellow"}, {"value": 65, "color": "green"}]}}}
    },
    {
      "id": 7, "title": "Win Rate 7d", "type": "gauge",
      "gridPos": {"x": 6, "y": 12, "w": 6, "h": 6},
      "targets": [{"expr": "nanorca_win_rate_7d * 100", "refId": "A"}],
      "fieldConfig": {"defaults": {"unit": "percent", "min": 0, "max": 100,
        "thresholds": {"steps": [{"value": null, "color": "red"}, {"value": 50, "color": "yellow"}, {"value": 65, "color": "green"}]}}}
    },
    {
      "id": 8, "title": "Open Positions", "type": "stat",
      "gridPos": {"x": 12, "y": 12, "w": 6, "h": 6},
      "targets": [{"expr": "nanorca_open_positions_count", "refId": "A"}],
      "fieldConfig": {"defaults": {"unit": "short"}}
    },
    {
      "id": 9, "title": "Last Trade Confidence", "type": "gauge",
      "gridPos": {"x": 18, "y": 12, "w": 6, "h": 6},
      "targets": [{"expr": "nanorca_confidence_last_trade", "refId": "A"}],
      "fieldConfig": {"defaults": {"min": 0, "max": 100,
        "thresholds": {"steps": [{"value": null, "color": "red"}, {"value": 65, "color": "yellow"}, {"value": 80, "color": "green"}]}}}
    },
    {
      "id": 10, "title": "Trades by Exchange", "type": "timeseries",
      "gridPos": {"x": 0, "y": 18, "w": 12, "h": 6},
      "targets": [
        {"expr": "increase(nanorca_trades_total[1h])", "legendFormat": "{{exchange}} trades/h", "refId": "A"}
      ]
    },
    {
      "id": 11, "title": "Scan Errors / Claude Errors", "type": "timeseries",
      "gridPos": {"x": 12, "y": 18, "w": 12, "h": 6},
      "targets": [
        {"expr": "increase(nanorca_scan_errors_total[5m])", "legendFormat": "Scan errors", "refId": "A"},
        {"expr": "increase(nanorca_claude_errors_total[5m])", "legendFormat": "Claude errors", "refId": "B"}
      ]
    }
  ]
}
